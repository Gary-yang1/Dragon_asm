# ── Server ──────────────────────────────────────────────────────────────────
API_PORT=8080
# GIN_MODE: debug | release | test
GIN_MODE=debug

# ── MySQL ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=asm
DB_PASSWORD=changeme
DB_NAME=asm
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=5
# Used by Makefile migrate-up / migrate-down (override if needed)
# DB_DSN=asm:changeme@tcp(localhost:3306)/asm?parseTime=true&loc=UTC&charset=utf8mb4

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-a-strong-random-secret
JWT_REFRESH_SECRET=replace-with-another-strong-random-secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# ── Discovery engine (Baiyan; no production defaults) ──────────────────────
# Trusted engine origin used only by the worker. Do not accept this from API input.
DISCOVERY_ENGINE_BASE_URL=http://localhost:9090
# Opaque Bearer token shared only by ASM worker and Baiyan.
DISCOVERY_ENGINE_TOKEN=replace-with-strong-engine-token
# HMAC secret used by the API to authenticate Baiyan callbacks.
DISCOVERY_CALLBACK_SECRET=replace-with-strong-hmac-secret
# Stable engine identity stored on each TaskRun; this is a reference, not a secret.
DISCOVERY_CALLBACK_SECRET_REF=baiyan-primary
# Optional bounded JSON map for rotation, e.g. {"baiyan-old":"...","baiyan-primary":"..."}.
DISCOVERY_CALLBACK_SECRETS=
# Optional secret for historical TaskRuns whose callback_secret_ref is empty.
DISCOVERY_CALLBACK_LEGACY_SECRET=
# Trusted ASM origin. Code appends /api/v1/discovery/callback and run query IDs.
DISCOVERY_CALLBACK_BASE_URL=http://localhost:8080
