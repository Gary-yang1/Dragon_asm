# ── Server ──────────────────────────────────────────────────────────────────
API_PORT=8080
# GIN_MODE: debug | release | test
GIN_MODE=debug

# ── MySQL ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=asm
DB_PASSWORD=changeme
DB_NAME=asm
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=5
# Used by Makefile migrate-up / migrate-down (override if needed)
# DB_DSN=asm:changeme@tcp(localhost:3306)/asm?parseTime=true&loc=UTC&charset=utf8mb4

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-a-strong-random-secret
JWT_REFRESH_SECRET=replace-with-another-strong-random-secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# ── Discovery engine (placeholder, engine not yet deployed) ─────────────────
ENGINE_BASE_URL=http://localhost:9090
# Shared HMAC secret for webhook callback verification
ENGINE_CALLBACK_SECRET=replace-with-strong-hmac-secret
# Callback URL registered with the engine
ENGINE_CALLBACK_URL=http://localhost:8080/api/discovery/callback
